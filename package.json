{
  "name": "genericcms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "content:generate": "node ./scripts/generate-content-artifacts.mjs",
    "dev": "npm run content:generate && vite",
    "build": "npm run content:generate && vite build",
    "check": "npm run lint && npm run build && npm run lint:functions",
    "deploy": "npm run build && firebase deploy --only hosting,functions",
    "deploy:functions": "npm run content:generate && firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "emulators": "npm run content:generate && firebase emulators:start",
    "firebase:doctor": "node ./scripts/firebase-doctor.cjs",
    "lint": "eslint .",
    "lint:functions": "npm run content:generate && npm --prefix functions run lint",
    "preview": "vite preview",
    "seed:firebase-data": "npm run content:generate && npm --prefix functions run seed:firestore",
    "snapshot:site": "node ./scripts/snapshot-live-site.mjs"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
